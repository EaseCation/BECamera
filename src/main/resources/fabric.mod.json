{
	"schemaVersion": 1,
	"id": "bedrockcameralib",
	"version": "${version}",
	"name": "NaKeR's Bedrock Camera Lib",
	"description": "Adds camera APIs similar to Bedrock's Script API ones.",
	"authors": [
		"NaKeR",
		"EaseCation"
	],
	"contact": {
		"homepage": "https://github.com/EaseCation/BECamera",
		"sources": "https://github.com/EaseCation/BECamera"
	},
	"license": "CC0-1.0",
	"icon": "assets/bedrockcameralib/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "nakern.be_camera.BedrockCameraLib",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		{
			"config": "bedrockcameralib.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.0",
		"minecraft": "${minecraft_dep}",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
